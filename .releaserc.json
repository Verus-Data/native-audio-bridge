{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "sed -i '' 's/let currentVersion = \".*\"/let currentVersion = \"${nextRelease.version}\"/' Package.swift && sed -i '' 's/public static let current = \".*\"/public static let current = \"${nextRelease.version}\"/' Sources/NativeAudioBridge/Version.swift"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "native-audio-bridge-*.tar.gz",
            "label": "Native Audio Bridge Binary"
          }
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["Package.swift", "Sources/NativeAudioBridge/Version.swift"],
        "message": "chore(release): ${nextRelease.version} [skip ci]"
      }
    ]
  ]
}